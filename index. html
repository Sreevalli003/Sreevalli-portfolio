<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Akarapu Sreevalli — Associate Software Engineer</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>

/* ═══════════════════════════════════════
   BASE RESET & DESIGN TOKENS
═══════════════════════════════════════ */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg:        #03050e;
  --bg1:       #060912;
  --bg2:       #0a0e1c;
  --surface:   #0e1220;
  --surface2:  #131828;
  --ink:       #e2e8f8;
  --ink2:      #8891b8;
  --ink3:      #555f85;
  --violet:    #8b7cf8;
  --cyan:      #22d3ee;
  --pink:      #f472b6;
  --emerald:   #34d399;
  --border:    rgba(139,124,248,.14);
  --glow-v:    rgba(139,124,248,.35);
  --glow-c:    rgba(34,211,238,.35);
  --r1: 16px; --r2: 20px;
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Outfit', sans-serif;
  background: var(--bg);
  color: var(--ink);
  overflow-x: hidden;
  cursor: none;
  -webkit-font-smoothing: antialiased;
}

/* ═══════════════════════════════════════
   LOADING SCREEN
═══════════════════════════════════════ */
#loader {
  position: fixed; inset: 0; z-index: 9999;
  background: var(--bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 28px;
  transition: opacity .9s cubic-bezier(.4,0,.2,1),
              visibility .9s cubic-bezier(.4,0,.2,1);
}
#loader.gone { opacity: 0; visibility: hidden; pointer-events: none; }

.ld-monogram {
  font-family: 'Outfit', sans-serif; font-weight: 900;
  font-size: 3rem; letter-spacing: -.02em;
  background: linear-gradient(135deg, var(--violet), var(--cyan));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: ldBreathe 1.6s ease-in-out infinite;
}
.ld-sub {
  font-size: .7rem; letter-spacing: .45em; text-transform: uppercase;
  color: var(--ink3); animation: ldBreathe 1.6s .3s ease-in-out infinite;
}
.ld-rail {
  width: 160px; height: 1px;
  background: rgba(255,255,255,.06); position: relative; overflow: hidden;
}
.ld-rail::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, var(--violet), var(--cyan), transparent);
  animation: ldScan 1.5s ease-in-out forwards;
  transform: translateX(-100%);
}
@keyframes ldScan    { to { transform: translateX(100%); } }
@keyframes ldBreathe { 0%,100%{opacity:.4} 50%{opacity:1} }

/* ═══════════════════════════════════════
   CUSTOM CURSOR
═══════════════════════════════════════ */
#cur {
  position: fixed; z-index: 9998; pointer-events: none;
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--cyan); transform: translate(-50%,-50%);
  box-shadow: 0 0 10px var(--cyan), 0 0 22px rgba(34,211,238,.5);
  transition: width .18s, height .18s, background .2s, box-shadow .2s;
}
#cur-halo {
  position: fixed; z-index: 9997; pointer-events: none;
  width: 36px; height: 36px; border-radius: 50%;
  border: 1px solid var(--violet); transform: translate(-50%,-50%);
  opacity: .6; transition: width .22s, height .22s, border-color .22s, opacity .22s;
}
body.hov #cur       { width: 14px; height: 14px; background: var(--pink); box-shadow: 0 0 14px var(--pink), 0 0 28px rgba(244,114,182,.5); }
body.hov #cur-halo  { width: 52px; height: 52px; border-color: var(--pink); opacity: .3; }

/* ═══════════════════════════════════════
   PARTICLE CANVAS
═══════════════════════════════════════ */
#pcv { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

/* ═══════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════ */
nav {
  position: fixed; inset: 0 0 auto 0; z-index: 500;
  padding: 0 48px;
  height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(3,5,14,.7); backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.nav-id {
  font-weight: 800; font-size: 1rem; letter-spacing: .06em;
  color: var(--violet); text-decoration: none;
}
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a {
  font-size: .78rem; letter-spacing: .1em; text-transform: uppercase;
  color: var(--ink3); text-decoration: none; position: relative;
  transition: color .25s;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -3px; left: 0;
  width: 0; height: 1px; background: var(--cyan); transition: width .3s;
}
.nav-links a:hover { color: var(--cyan); }
.nav-links a:hover::after { width: 100%; }

/* ═══════════════════════════════════════
   MAIN LAYER
═══════════════════════════════════════ */
main { position: relative; z-index: 1; }

/* ═══════════════════════════════════════
   HERO
═══════════════════════════════════════ */
#hero {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80px 24px 60px;
  text-align: center;
  position: relative;
}

/* orbit ring behind everything */
.hero-orbit {
  position: absolute; border-radius: 50%;
  border: 1px solid rgba(139,124,248,.08);
  animation: orbitSpin 30s linear infinite;
  pointer-events: none;
}
.ho1 { width: 520px; height: 520px; top: 50%; left: 50%; transform: translate(-50%,-50%); }
.ho2 { width: 780px; height: 780px; top: 50%; left: 50%; transform: translate(-50%,-50%); animation-duration: 50s; animation-direction: reverse; }
@keyframes orbitSpin { to { transform: translate(-50%,-50%) rotate(360deg); } }

.h-eyebrow {
  font-size: .7rem; letter-spacing: .42em; text-transform: uppercase;
  color: var(--cyan); margin-bottom: 20px;
  opacity: 0; animation: riseUp .6s 1.9s ease forwards;
}
.h-name {
  font-weight: 900; font-size: clamp(3rem, 10vw, 7.5rem);
  line-height: .95; letter-spacing: -.03em;
  background: linear-gradient(
    90deg,
    #fff 0%, #fff 12%,
    var(--violet) 28%, var(--cyan) 46%,
    var(--pink) 62%, var(--emerald) 76%,
    #fff 88%, #fff 100%
  );
  background-size: 280% 100%;
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  animation: shimmer 5s linear infinite, riseUp .8s 2.1s ease forwards;
  opacity: 0;
}
@keyframes shimmer { 0%{background-position:230% 0} 100%{background-position:-230% 0} }

.h-role {
  margin-top: 18px;
  font-size: clamp(.9rem, 2.5vw, 1.2rem);
  color: var(--ink2); font-weight: 300; letter-spacing: .02em;
  opacity: 0; animation: riseUp .7s 2.3s ease forwards;
}
.h-badge {
  margin-top: 14px; display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 18px; border-radius: 100px;
  background: rgba(34,211,238,.07); border: 1px solid rgba(34,211,238,.22);
  font-size: .78rem; color: var(--cyan); letter-spacing: .05em;
  opacity: 0; animation: riseUp .7s 2.5s ease forwards;
}
.h-badge-dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--emerald);
  animation: pulse 1.8s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.2} }

.h-cta {
  margin-top: 44px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
  opacity: 0; animation: riseUp .7s 2.7s ease forwards;
}
.btn {
  padding: 13px 32px; border-radius: 8px; text-decoration: none; cursor: none;
  font-size: .82rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase;
  display: inline-block; transition: transform .22s, box-shadow .22s;
}
.btn-fill {
  background: linear-gradient(135deg, var(--violet), var(--cyan));
  color: #fff; box-shadow: 0 0 28px rgba(139,124,248,.4);
}
.btn-fill:hover { transform: translateY(-3px); box-shadow: 0 0 44px rgba(34,211,238,.55); }
.btn-ghost {
  border: 1px solid var(--border); color: var(--ink); background: transparent;
}
.btn-ghost:hover { border-color: var(--cyan); color: var(--cyan); transform: translateY(-3px); }

/* ── FLOATING 3D CARD ── */
.card-stage {
  margin-top: 56px; perspective: 1000px;
  opacity: 0; animation: riseUp 1s 3s ease forwards;
}
.card-3d {
  width: min(400px, 92vw);
  background: linear-gradient(145deg, var(--surface) 0%, var(--surface2) 100%);
  border: 1px solid var(--border);
  border-radius: var(--r2); padding: 30px;
  text-align: left; position: relative; overflow: hidden;
  animation: floatCard 10s ease-in-out infinite;
}
.card-3d::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--violet), var(--cyan), transparent);
}
.card-3d::after {
  content: '';
  position: absolute; inset: 0; border-radius: var(--r2);
  background: linear-gradient(135deg, rgba(139,124,248,.07) 0%, transparent 60%);
}
@keyframes floatCard {
  0%   { transform: rotateY(-8deg) rotateX(5deg) translateY(0px);   box-shadow: 0 24px 64px rgba(0,0,0,.6), 0 0 48px rgba(139,124,248,.14); }
  20%  { transform: rotateY(4deg)  rotateX(-4deg) translateY(-16px); box-shadow: 0 44px 88px rgba(0,0,0,.5), 0 0 64px rgba(34,211,238,.2); }
  45%  { transform: rotateY(8deg)  rotateX(5deg)  translateY(-10px); box-shadow: 0 36px 76px rgba(0,0,0,.55),0 0 56px rgba(244,114,182,.16); }
  70%  { transform: rotateY(-4deg) rotateX(-5deg) translateY(-18px); box-shadow: 0 44px 88px rgba(0,0,0,.5), 0 0 64px rgba(52,211,153,.16); }
  100% { transform: rotateY(-8deg) rotateX(5deg)  translateY(0px);   box-shadow: 0 24px 64px rgba(0,0,0,.6), 0 0 48px rgba(139,124,248,.14); }
}
.card-pill {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 4px 12px; border-radius: 100px;
  font-size: .68rem; letter-spacing: .12em; text-transform: uppercase;
  background: rgba(52,211,153,.1); color: var(--emerald);
  border: 1px solid rgba(52,211,153,.25); margin-bottom: 16px;
  position: relative; z-index: 1;
}
.card-pill-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--emerald); animation: pulse 1.8s ease-in-out infinite; }
.card-name { font-weight: 800; font-size: 1.3rem; letter-spacing: -.01em; position: relative; z-index: 1; }
.card-title { font-size: .82rem; color: var(--ink2); margin-top: 5px; position: relative; z-index: 1; }
.card-line { width: 100%; height: 1px; background: var(--border); margin: 18px 0; position: relative; z-index: 1; }
.card-kpis { display: flex; gap: 28px; position: relative; z-index: 1; }
.kpi-n { font-family: 'Space Mono', monospace; font-size: 1.5rem; color: var(--cyan); font-weight: 700; }
.kpi-l { font-size: .65rem; color: var(--ink3); letter-spacing: .06em; margin-top: 3px; text-transform: uppercase; }

/* ═══════════════════════════════════════
   SECTION WRAPPER
═══════════════════════════════════════ */
.wrap { max-width: 1120px; margin: 0 auto; padding: 108px 28px; }

.label {
  font-size: .68rem; letter-spacing: .38em; text-transform: uppercase;
  color: var(--violet); margin-bottom: 10px;
  display: flex; align-items: center; gap: 10px;
}
.label::before { content: ''; width: 28px; height: 1px; background: var(--violet); flex-shrink: 0; }
.title {
  font-weight: 800; font-size: clamp(1.9rem, 5vw, 3.2rem);
  line-height: 1.05; letter-spacing: -.02em; margin-bottom: 48px;
}

/* ═══════════════════════════════════════
   SCROLL REVEAL
═══════════════════════════════════════ */
.sr { opacity: 0; transition: opacity .8s cubic-bezier(.4,0,.2,1), transform .8s cubic-bezier(.4,0,.2,1); }
.sr.up    { transform: translateY(56px); }
.sr.left  { transform: translateX(-68px); }
.sr.right { transform: translateX(68px); }
.sr.vis   { opacity: 1; transform: none; }

/* ═══════════════════════════════════════
   ABOUT / PROFILE
═══════════════════════════════════════ */
#about .inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 64px; align-items: start;
}
.about-prose p {
  font-size: .97rem; line-height: 1.9; color: var(--ink2); margin-bottom: 14px;
}
.about-prose p strong { color: var(--cyan); font-weight: 600; }
.meta-pills {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 28px;
}
.mp {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 10px; padding: 11px 14px;
  font-size: .8rem; color: var(--ink2); line-height: 1.4;
}
.mp b { display: block; font-weight: 600; color: var(--ink); font-size: .88rem; margin-bottom: 3px; }

.edu-stack { display: flex; flex-direction: column; gap: 14px; }
.edu-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r1); padding: 22px 22px 22px 26px;
  position: relative; overflow: hidden;
  transition: border-color .3s, transform .3s;
}
.edu-card::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
  background: linear-gradient(180deg, var(--violet), var(--cyan));
}
.edu-card:hover { border-color: rgba(139,124,248,.35); transform: translateX(4px); }
.edu-deg { font-weight: 700; font-size: .98rem; }
.edu-school { font-size: .82rem; color: var(--ink2); margin-top: 4px; }
.edu-meta { font-size: .75rem; color: var(--cyan); margin-top: 8px; font-family: 'Space Mono', monospace; }

/* ═══════════════════════════════════════
   MARQUEE BAND
═══════════════════════════════════════ */
.mq-band {
  overflow: hidden; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  background: var(--surface); padding: 0; position: relative; z-index: 1;
}
.mq-band::before,
.mq-band::after {
  content: ''; position: absolute; top: 0; bottom: 0; width: 120px; z-index: 2;
  pointer-events: none;
}
.mq-band::before { left: 0; background: linear-gradient(90deg, var(--surface), transparent); }
.mq-band::after  { right: 0; background: linear-gradient(-90deg, var(--surface), transparent); }
.mq-rail {
  display: flex; width: max-content; padding: 20px 0;
  animation: mqRoll 24s linear infinite;
}
.mq-item {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 0 42px; flex-shrink: 0;
  font-size: .78rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
  color: var(--ink3);
  transition: color .25s;
}
.mq-item:hover { color: var(--ink); }
.mq-gem {
  width: 5px; height: 5px; border-radius: 1px; flex-shrink: 0;
  background: var(--violet); transform: rotate(45deg);
}
@keyframes mqRoll { from{transform:translateX(0)} to{transform:translateX(-50%)} }

/* ═══════════════════════════════════════
   SKILLS
═══════════════════════════════════════ */
.skills-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 22px;
}
.sk {  }
.sk-top { display: flex; justify-content: space-between; margin-bottom: 9px; font-size: .84rem; color: var(--ink); }
.sk-pct { font-family: 'Space Mono', monospace; color: var(--cyan); font-size: .78rem; }
.sk-rail { height: 3px; background: rgba(255,255,255,.06); border-radius: 3px; overflow: hidden; }
.sk-bar {
  height: 100%; width: 0; border-radius: 3px;
  background: linear-gradient(90deg, var(--violet), var(--cyan));
  transition: width 1.4s cubic-bezier(.25,.8,.25,1);
  box-shadow: 0 0 10px rgba(34,211,238,.4);
}

/* ═══════════════════════════════════════
   EXPERIENCE TIMELINE
═══════════════════════════════════════ */
.timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
.timeline::before {
  content: ''; position: absolute; left: 16px; top: 8px; bottom: 8px;
  width: 1px; background: var(--border);
}
.tl-item {
  display: grid; grid-template-columns: 44px 1fr;
  gap: 20px; margin-bottom: 32px;
}
.tl-dot {
  width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0; margin-top: 2px;
  background: var(--surface2); border: 2px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: .7rem; color: var(--violet); font-weight: 700;
  position: relative; z-index: 1;
  transition: border-color .3s;
}
.tl-item:hover .tl-dot { border-color: var(--violet); }
.tl-body {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r1); padding: 22px 24px;
  transition: border-color .3s, transform .3s;
}
.tl-body:hover { border-color: rgba(139,124,248,.3); transform: translateX(4px); }
.tl-role { font-weight: 700; font-size: 1rem; }
.tl-co   { color: var(--cyan); font-size: .84rem; margin-top: 4px; }
.tl-when { color: var(--ink3); font-size: .73rem; margin-top: 5px; font-family: 'Space Mono', monospace; }
.tl-desc { color: var(--ink2); font-size: .84rem; line-height: 1.82; margin-top: 12px; }

/* ═══════════════════════════════════════
   PROJECT CARDS
═══════════════════════════════════════ */
.proj-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(300px,1fr));
  gap: 22px;
}
.proj {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r2); padding: 30px;
  position: relative; overflow: hidden; cursor: none;
  transition: transform .32s cubic-bezier(.4,0,.2,1),
              box-shadow .32s;
}
/* top-border gradient sweep */
.proj::before {
  content: ''; position: absolute; top: 0; left: -120%; right: 120%; height: 2px;
  background: linear-gradient(90deg, transparent, var(--cyan), var(--pink), var(--violet), transparent);
  transition: left .6s cubic-bezier(.4,0,.2,1), right .6s cubic-bezier(.4,0,.2,1);
}
.proj:hover::before { left: 0; right: 0; }
.proj:hover {
  transform: translateY(-8px);
  box-shadow: 0 28px 64px rgba(0,0,0,.55), 0 0 36px rgba(139,124,248,.16);
}
.proj-num {
  font-family: 'Space Mono', monospace; font-size: 2.2rem; font-weight: 700;
  color: rgba(139,124,248,.1); margin-bottom: 10px; line-height: 1;
}
.proj-name { font-weight: 700; font-size: 1.08rem; margin-bottom: 12px; }
.proj-period {
  font-size: .7rem; font-family: 'Space Mono', monospace; color: var(--ink3);
  margin-bottom: 12px; letter-spacing: .04em;
}
.proj-desc { font-size: .84rem; color: var(--ink2); line-height: 1.8; }
.tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 18px; }
.tag {
  padding: 3px 10px; border-radius: 5px;
  font-size: .66rem; letter-spacing: .07em; text-transform: uppercase; font-weight: 600;
  background: rgba(139,124,248,.1); color: var(--violet);
  border: 1px solid rgba(139,124,248,.2);
}

/* ═══════════════════════════════════════
   CERTIFICATIONS
═══════════════════════════════════════ */
.cert-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr));
  gap: 16px;
}
.cert {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r1); padding: 22px 20px;
  transition: border-color .3s, transform .3s, box-shadow .3s;
  position: relative; overflow: hidden;
}
.cert::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--violet), var(--cyan));
  transform: scaleX(0); transform-origin: left;
  transition: transform .4s cubic-bezier(.4,0,.2,1);
}
.cert:hover { border-color: rgba(139,124,248,.3); transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,.4); }
.cert:hover::after { transform: scaleX(1); }
.cert-icon { font-size: 1.5rem; margin-bottom: 12px; }
.cert-name { font-weight: 700; font-size: .94rem; margin-bottom: 6px; }
.cert-by   { font-size: .77rem; color: var(--cyan); }

/* ═══════════════════════════════════════
   CONTACT — pulsing ripple avatar (right side)
═══════════════════════════════════════ */
#contact { background: var(--bg1); }
#contact .inner {
  max-width: 1120px; margin: 0 auto; padding: 108px 28px;
  display: grid; grid-template-columns: 1fr auto;
  gap: 80px; align-items: center;
}
.contact-text .label { margin-bottom: 10px; }
.contact-h { font-weight: 800; font-size: clamp(1.9rem,4.5vw,3rem); letter-spacing: -.02em; margin-bottom: 16px; }
.contact-sub { font-size: .95rem; color: var(--ink2); line-height: 1.82; margin-bottom: 36px; max-width: 460px; }
.contact-links { display: flex; flex-direction: column; gap: 12px; }
.clink {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 12px 22px; border-radius: 10px;
  background: var(--surface); border: 1px solid var(--border);
  color: va
